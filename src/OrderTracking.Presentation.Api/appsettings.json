{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=15432;Database=order_tracking;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:19092",
    "ClientId": "order-tracking-api",
    "OrderStatusTopic": "order.status.v1",
    "ConsumerGroupId": "order-tracking-api",
    "EnableAutoCommit": false,
    "AutoOffsetReset": "Earliest"
  },
  "OpenTelemetry": {
    "ServiceName": "order-tracking-api",
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    },
    "Exporters": {
      "Otlp": true,
      "Console": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
