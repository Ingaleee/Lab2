{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=15432;Database=order_tracking;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:19092",
    "ClientId": "order-tracking-worker",
    "OrderStatusTopic": "order.status.v1"
  },
  "OutboxDispatcher": {
    "BatchSize": 50,
    "PollIntervalSeconds": 2,
    "MaxAttempts": 10
  },
  "OpenTelemetry": {
    "ServiceName": "order-tracking-worker",
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    },
    "Exporters": {
      "Otlp": true,
      "Console": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
